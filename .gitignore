# API .gitignore - Exclude heavy models and build artifacts

# Large ML Models (see MODELS_SETUP.md for setup instructions)
/models/pixel-art-model/
/models/SpriteStack_Model_Slim_v2/
/models/**/*.safetensors
/models/**/*.ckpt
/models/**/*.pt
/models/**/*.pth
/models/**/*.bin

# Model checkpoints (3rd party)
*.ckpt
*.pth
*.pt

# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Environment
.venv/
venv/
env/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log
debug_sprite.png

# Integration packages (optional, managed separately)
/pixel_rife_rgba_integration_package/
